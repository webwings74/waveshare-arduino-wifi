{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "arduino-compile-waveshare",
			"type": "shell",
			"command": "arduino-cli",
			"args": [
				"compile",
				"-b",
				"arduino:renesas_uno:unor4wifi",
				"--library",
				"${workspaceFolder}/epd12in48",
				"${workspaceFolder}/waveshare-arduino-wifi.ino"
			]
		},
		{
			"label": "arduino-board-list",
			"type": "shell",
			"command": "arduino-cli",
			"args": [
				"board",
				"list"
			]
		},
		{
			"label": "arduino-upload-waveshare",
			"type": "shell",
			"command": "arduino-cli",
			"args": [
				"upload",
				"-b",
				"arduino:renesas_uno:unor4wifi",
				"-p",
				"/dev/cu.usbmodemF412FA9FE9E82",
				"${workspaceFolder}/waveshare-arduino-wifi.ino"
			]
		}
	]
}